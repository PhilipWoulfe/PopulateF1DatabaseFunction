@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject IUserSession UserSession
@inject IWebAssemblyHostEnvironment HostEnvironment

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            @if (HostEnvironment.IsDevelopment())
            {
                @* This helps you test the UI without needing to actually login via CF *@
                <button class="btn btn-outline-warning btn-sm me-2" @onclick="ToggleUser">
                    Test Mode: Toggle Auth
                </button>
            }
            
            <AuthorizeView>
                <Authorized>
                    <span class="me-3">Hi, @context.User.Identity?.Name</span>
                    <a href="https://f1-team.cloudflareaccess.com/cdn-cgi/access/logout" class="btn btn-sm btn-outline-danger">Logout</a>
                </Authorized>
                <NotAuthorized>
                    @* Forces a full page load to 'results' so Cloudflare can intercept the request *@
                    <button class="btn btn-primary btn-sm" @onclick='() => Navigation.NavigateTo("results", true)'>Login</button>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private async Task ToggleUser()
    {
        // This likely modifies the headers/state in your dev environment
        await UserSession.InitializeAsync();
        
        // Force the layout to re-evaluate the AuthorizeView
        StateHasChanged(); 
    }
}