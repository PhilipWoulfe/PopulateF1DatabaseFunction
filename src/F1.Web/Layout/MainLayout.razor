@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject IUserSession UserSession
@inject IWebAssemblyHostEnvironment HostEnvironment
@inject HttpClient Http
@using System.Net.Http.Json

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        @if (HostEnvironment.IsDevelopment())
        {
            <div class="alert alert-warning text-center m-0 fw-bold rounded-0 py-1" role="alert">
                🚧 DEVELOPMENT MODE 🚧
            </div>
        }
        else if (HostEnvironment.IsStaging() || HostEnvironment.Environment == "Test")
        {
            <div class="alert alert-danger text-center m-0 fw-bold rounded-0 py-1" role="alert">
                🧪 QA ENVIRONMENT - Build: @_appVersion
            </div>
        }

        <div class="top-row px-4">
            @if (HostEnvironment.IsDevelopment())
            {
                @* This helps you test the UI without needing to actually login via CF *@
                <button class="btn btn-outline-warning btn-sm me-2" @onclick="ToggleUser">
                    Test Mode: Toggle Auth
                </button>
            }
            
            <AuthorizeView>
                <Authorized>
                    <span class="me-3">Hi, @context.User.Identity?.Name</span>
                    <a href="https://f1-team.cloudflareaccess.com/cdn-cgi/access/logout" class="btn btn-sm btn-outline-danger">Logout</a>
                </Authorized>
                <NotAuthorized>
                    @* Forces a full page load to 'results' so Cloudflare can intercept the request *@
                    <button class="btn btn-primary btn-sm" @onclick='() => Navigation.NavigateTo("results", true)'>Login</button>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>

        @if (HostEnvironment.IsProduction())
        {
            <div class="text-muted text-end pe-4 pb-2" style="font-size: 0.7rem; opacity: 0.6;">
                v. @_appVersion
            </div>
        }
    </main>
</div>

@code {
    private string _appVersion = "Loading...";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Initialize the user session on startup by fetching user details from the API.
            await UserSession.InitializeAsync();

            // Create a temporary client to fetch from the Origin (Web App), not the API.
            // This avoids using the API client (with its auth handlers) for a simple static file.
            using var localClient = new HttpClient { BaseAddress = new Uri(Navigation.BaseUri) };
            var versionModel = await localClient.GetFromJsonAsync<VersionModel>("version.json");

            if (versionModel?.Version is not null)
            {
                // Use the first 7 characters for a short hash display
                _appVersion = versionModel.Version.Substring(0, Math.Min(7, versionModel.Version.Length));
            }
        }
        catch
        {
            _appVersion = "Local";
        }
    }

    private async Task ToggleUser()
    {
        // This likely modifies the headers/state in your dev environment
        await UserSession.InitializeAsync();
        
        // Force the layout to re-evaluate the AuthorizeView
        StateHasChanged(); 
    }

    private class VersionModel { public string Version { get; set; } }
}