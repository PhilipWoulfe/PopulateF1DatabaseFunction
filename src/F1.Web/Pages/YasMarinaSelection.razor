@page "/yas-marina-selection"
@using F1.Web.Models
@using F1.Web.Services.Api
@using System.Net
@implements IAsyncDisposable
@inject IDriversApiService DriversService
@inject ISelectionApiService SelectionService
@inject IRaceMetadataApiService RaceMetadataService
@inject F1.Web.Services.ITimeProvider TimeProvider
@inject F1.Web.Services.IMockDateService MockDateService

<h1>Yas Marina GP 2025 Selection</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

@if (drivers is null || raceConfig is null)
{
    <p><em>Loading...</em></p>
}
else
{
    @if (raceMetadata is not null)
    {
        <div class="alert alert-primary">
            <h4>Race Questions</h4>
            <p class="mb-2"><strong>H2H:</strong> @raceMetadata.H2HQuestion</p>
            <p class="mb-0"><strong>Bonus:</strong> @raceMetadata.BonusQuestion</p>
        </div>
    }

    <div class="alert alert-info">
        <strong>Countdown:</strong> @GetCountdownText()
    </div>

    <div class="alert alert-warning">
        Locking for Pre-Qualy gives +50% points but prevents changes after Sunday 13:00 UTC!
    </div>

    <EditForm Model="formModel" OnValidSubmit="SaveSelectionAsync">
        <h4>Top 5 Driver Predictions</h4>
        @for (var i = 0; i < 5; i++)
        {
            var rank = i;
            <div class="mb-2">
                <label class="form-label">Position @(i + 1)</label>
                <select id="driver-select-@(i + 1)" class="form-select" value="@formModel.SelectedDriverIds[rank]" @onchange="e => OnDriverChanged(rank, e.Value?.ToString())" disabled="@isReadOnly">
                    <option value="">-- Select driver --</option>
                    @foreach (var driver in drivers)
                    {
                        <option value="@driver.DriverId">@driver.FullName (@driver.DriverId)</option>
                    }
                </select>
            </div>
        }

        <h4 class="mt-4">Bet Strategy</h4>
        <InputRadioGroup @bind-Value="formModel.SelectedBetType">
            <div class="form-check">
                <InputRadio id="strategy-regular" class="form-check-input" Value="BetType.Regular" disabled="@isReadOnly" />
                <label class="form-check-label" for="strategy-regular">Regular</label>
            </div>
            <div class="form-check">
                <InputRadio id="strategy-prequaly" class="form-check-input" Value="BetType.PreQualy" disabled="@isReadOnly" />
                <label class="form-check-label" for="strategy-prequaly">Pre-Qualy</label>
            </div>
            <div class="form-check mb-3">
                <InputRadio id="strategy-allornothing" class="form-check-input" Value="BetType.AllOrNothing" disabled="@isReadOnly" />
                <label class="form-check-label" for="strategy-allornothing">All-or-Nothing</label>
            </div>
        </InputRadioGroup>

        <button id="submit-selection" class="btn btn-primary" type="submit" disabled="@isReadOnly">Save Selection</button>

        @if (isReadOnly)
        {
            <p class="text-muted mt-2">This pre-qualy selection is locked.</p>
        }
    </EditForm>
}

@code {
    private const string RaceId = "2025-24-yas_marina";

    private Driver[]? drivers;
    private RaceConfig? raceConfig;
    private RaceQuestionMetadata? raceMetadata;
    private readonly YasMarinaSelectionFormModel formModel = new();
    private string? errorMessage;
    private string? successMessage;
    private bool isReadOnly;
    private PeriodicTimer? countdownTimer;
    private CancellationTokenSource? timerCts;
    private Task? tickTask;

    protected override async Task OnInitializedAsync()
    {
        await MockDateService.RefreshAsync();
        await LoadDataAsync();
        StartCountdownTimer();
    }

    public async ValueTask DisposeAsync()
    {
        var cts = timerCts;
        var timer = countdownTimer;
        var task = tickTask;
        timerCts = null;
        countdownTimer = null;
        tickTask = null;

        if (cts is not null)
        {
            await cts.CancelAsync();
        }

        if (task is not null)
        {
            await task;
        }

        cts?.Dispose();
        timer?.Dispose();
    }

    private async Task LoadDataAsync()
    {
        errorMessage = null;
        successMessage = null;

        try
        {
            drivers = await DriversService.GetAllAsync();
            raceConfig = await SelectionService.GetConfigAsync(RaceId);
            raceMetadata = await RaceMetadataService.GetPublishedAsync(RaceId);
            await LoadExistingSelectionAsync();
            await LoadCurrentSelectionsAsync();

            if (!isReadOnly && raceConfig is not null && TimeProvider.UtcNow >= raceConfig.FinalDeadlineUtc)
            {
                isReadOnly = true;
            }
        }
        catch (ApiServiceException ex)
        {
            errorMessage = $"Error loading data: {ex.Error.Message}";
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading data: {ex.Message}";
        }
    }

    private async Task LoadExistingSelectionAsync()
    {
        var existing = await SelectionService.GetMineAsync(RaceId);
        if (existing is null)
        {
            return;
        }

        ApplySelectionToForm(existing);
    }

    private async Task LoadCurrentSelectionsAsync()
    {
        var snapshot = await SelectionService.GetCurrentAsync();

        if (snapshot.Length == 0)
        {
            return;
        }

        var rankedDrivers = snapshot
            .Where(row => !string.IsNullOrWhiteSpace(row.DriverId))
            .OrderBy(row => row.Position <= 0 ? int.MaxValue : row.Position)
            .ThenBy(row => row.Timestamp)
            .Select(row => row.DriverId)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Take(formModel.SelectedDriverIds.Count)
            .ToList();

        for (var i = 0; i < formModel.SelectedDriverIds.Count; i++)
        {
            formModel.SelectedDriverIds[i] = i < rankedDrivers.Count ? rankedDrivers[i] : string.Empty;
        }

        var selectionType = snapshot
            .Select(row => row.SelectionType)
            .FirstOrDefault(type => !string.IsNullOrWhiteSpace(type));

        if (Enum.TryParse<BetType>(selectionType, ignoreCase: true, out var mappedBetType))
        {
            formModel.SelectedBetType = mappedBetType;
        }
    }

    private async Task SaveSelectionAsync()
    {
        errorMessage = null;
        successMessage = null;

        var submission = new SelectionSubmission
        {
            BetType = formModel.SelectedBetType,
            OrderedSelections = formModel.SelectedDriverIds
                .Select((driverId, index) => new SelectionPosition { Position = index + 1, DriverId = driverId })
                .ToList(),
            Selections = formModel.SelectedDriverIds.ToList()
        };

        try
        {
            var saved = await SelectionService.SaveMineAsync(RaceId, submission);
            successMessage = "Selection saved successfully.";
            ApplySelectionToForm(saved);
            await LoadCurrentSelectionsAsync();
        }
        catch (ApiServiceException ex)
        {
            errorMessage = GetSaveErrorMessage(ex);
        }
        catch (Exception)
        {
            errorMessage = "Unable to save selection.";
        }
    }

    private static string GetSaveErrorMessage(ApiServiceException exception)
    {
        return exception.Error.StatusCode switch
        {
            HttpStatusCode.Unauthorized or HttpStatusCode.Forbidden => "You are not authorized to save this selection.",
            _ => exception.Error.Message
        };
    }

    private void ApplySelectionToForm(Selection selection)
    {
        formModel.SelectedBetType = selection.BetType;

        var selections = (selection.OrderedSelections ?? [])
            .Where(item => !string.IsNullOrWhiteSpace(item.DriverId))
            .OrderBy(item => item.Position)
            .Select(item => item.DriverId)
            .ToList();

        if (selections.Count == 0)
        {
            selections = selection.Selections ?? [];
        }

        for (var i = 0; i < formModel.SelectedDriverIds.Count; i++)
        {
            formModel.SelectedDriverIds[i] = i < selections.Count ? selections[i] : "";
        }

        isReadOnly = selection.IsLocked;
    }

    private void OnDriverChanged(int index, string? driverId)
    {
        formModel.SelectedDriverIds[index] = driverId ?? string.Empty;
    }

    private string GetCountdownText()
    {
        if (raceConfig is null)
        {
            return string.Empty;
        }

        var nowUtc = TimeProvider.UtcNow;
        var nextDeadline = nowUtc < raceConfig.PreQualyDeadlineUtc ? raceConfig.PreQualyDeadlineUtc : raceConfig.FinalDeadlineUtc;
        var label = nowUtc < raceConfig.PreQualyDeadlineUtc ? "Pre-Qualy lock" : "Final submission";

        if (nowUtc > raceConfig.FinalDeadlineUtc)
        {
            return "All deadlines have passed.";
        }

        var remaining = nextDeadline - nowUtc;
        return $"{label} in {remaining.Days}d {remaining.Hours}h {remaining.Minutes}m {remaining.Seconds}s (UTC).";
    }

    private void StartCountdownTimer()
    {
        timerCts = new CancellationTokenSource();
        countdownTimer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        tickTask = TickCountdownAsync(timerCts.Token);
    }

    private async Task TickCountdownAsync(CancellationToken cancellationToken)
    {
        if (countdownTimer is null)
        {
            return;
        }

        try
        {
            while (await countdownTimer.WaitForNextTickAsync(cancellationToken))
            {
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Unexpected error in countdown timer: {ex}");
        }
    }

}
