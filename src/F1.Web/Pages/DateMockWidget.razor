@* DateMockWidget.razor: Appears for admin users when date mocking is enabled. Allows setting mock date/time. *@
@using F1.Web.Services.Api

@if (ShowWidget)
{
    <div class="date-mock-widget" style="position:fixed;top:50px;right:0;z-index:2000;background:#fff;border:1px solid #ccc;padding:1rem;box-shadow:-2px 2px 8px #0002;min-width:260px;">
        <h5>Date Mocking</h5>
        <div>
            <label for="mockDate">Mock Date/Time (local browser time):</label>
            <input id="mockDate" type="datetime-local" @bind-value="LocalMockDate" @bind-value:event="oninput" />
        </div>
        <button class="btn btn-sm btn-secondary mt-2" @onclick="SetMockDate">Set</button>
        <button class="btn btn-sm btn-secondary mt-2 ms-2" @onclick="ClearMockDate">Clear</button>
        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="text-danger mt-2" role="alert">@ErrorMessage</div>
        }
    </div>
}

@code {
    [Inject] public IUserSession UserSession { get; set; } = default!;
    [Inject] public IMockDateService MockDateService { get; set; } = default!;
    [Inject] public NavigationManager Nav { get; set; } = default!;


    // The value bound to the input, always in local time
    private DateTime? LocalMockDate { get; set; }
    // The value in UTC, used for API
    private DateTime? MockDateUtc { get; set; }
    private string? ErrorMessage { get; set; }
    private bool ShowWidget => (UserSession.User?.IsAdmin ?? false) && DateMockingEnabled;
    private bool DateMockingEnabled => true; // TODO: Replace with config/env check

    protected override async Task OnInitializedAsync()
    {
        if (!ShowWidget)
        {
            return;
        }

        await MockDateService.RefreshAsync();

        var mockDateUtc = MockDateService.GetMockDate();
        if (mockDateUtc.HasValue)
        {
            MockDateUtc = DateTime.SpecifyKind(mockDateUtc.Value, DateTimeKind.Utc);
            LocalMockDate = MockDateUtc.Value.ToLocalTime();
        }
        else
        {
            MockDateUtc = DateTime.UtcNow;
            LocalMockDate = MockDateUtc.Value.ToLocalTime();
        }
    }

    private async Task SetMockDate()
    {
        if (LocalMockDate.HasValue)
        {
            try
            {
                MockDateUtc = DateTime.SpecifyKind(LocalMockDate.Value, DateTimeKind.Local).ToUniversalTime();
                await MockDateService.SetMockDateAsync(MockDateUtc);
                ErrorMessage = null;
                Nav.NavigateTo(Nav.Uri, forceLoad: true);
            }
            catch (ApiServiceException ex)
            {
                ErrorMessage = ex.Error.Message;
            }
            catch (Exception)
            {
                ErrorMessage = "Unable to set mock date right now. Please try again.";
            }
        }
    }

    private async Task ClearMockDate()
    {
        try
        {
            await MockDateService.SetMockDateAsync(null);
            MockDateUtc = null;
            LocalMockDate = null;
            ErrorMessage = null;
            Nav.NavigateTo(Nav.Uri, forceLoad: true);
        }
        catch (ApiServiceException ex)
        {
            ErrorMessage = ex.Error.Message;
        }
        catch (Exception)
        {
            ErrorMessage = "Unable to clear mock date right now. Please try again.";
        }
    }
}
