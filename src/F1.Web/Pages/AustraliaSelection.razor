@page "/australia-selection"
@using F1.Web.Models
@using System.Net
@using System.Net.Http.Json
@implements IAsyncDisposable
@inject HttpClient Http

<h1>Australia GP 2026 Selection</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

@if (drivers is null || raceConfig is null)
{
    <p><em>Loading...</em></p>
}
else
{
    @if (raceMetadata is not null)
    {
        <div class="alert alert-primary">
            <h4>Race Questions</h4>
            <p class="mb-2"><strong>H2H:</strong> @raceMetadata.H2HQuestion</p>
            <p class="mb-0"><strong>Bonus:</strong> @raceMetadata.BonusQuestion</p>
        </div>
    }

    <div class="alert alert-info">
        <strong>Countdown:</strong> @GetCountdownText()
    </div>

    <div class="alert alert-warning">
        Locking for Pre-Qualy gives +50% points but prevents changes after Saturday 04:30!
    </div>

    <EditForm Model="this" OnValidSubmit="SaveSelectionAsync">
        <h4>Top 5 Driver Predictions</h4>
        @for (var i = 0; i < 5; i++)
        {
            var rank = i;
            <div class="mb-2">
                <label class="form-label">Position @(i + 1)</label>
                <select id="driver-select-@(i + 1)" class="form-select" value="@selectedDriverIds[rank]" @onchange="e => OnDriverChanged(rank, e.Value?.ToString())" disabled="@isReadOnly">
                    <option value="">-- Select driver --</option>
                    @foreach (var driver in drivers)
                    {
                        <option value="@driver.DriverId">@driver.FullName (@driver.DriverId)</option>
                    }
                </select>
            </div>
        }

        <h4 class="mt-4">Bet Strategy</h4>
        <InputRadioGroup @bind-Value="selectedBetType">
            <div class="form-check">
                <InputRadio id="strategy-regular" class="form-check-input" Value="BetType.Regular" disabled="@isReadOnly" />
                <label class="form-check-label" for="strategy-regular">Regular</label>
            </div>
            <div class="form-check">
                <InputRadio id="strategy-prequaly" class="form-check-input" Value="BetType.PreQualy" disabled="@isReadOnly" />
                <label class="form-check-label" for="strategy-prequaly">Pre-Qualy</label>
            </div>
            <div class="form-check mb-3">
                <InputRadio id="strategy-allornothing" class="form-check-input" Value="BetType.AllOrNothing" disabled="@isReadOnly" />
                <label class="form-check-label" for="strategy-allornothing">All-or-Nothing</label>
            </div>
        </InputRadioGroup>

        <button id="submit-selection" class="btn btn-primary" type="submit" disabled="@isReadOnly">Save Selection</button>

        @if (isReadOnly)
        {
            <p class="text-muted mt-2">This pre-qualy selection is locked.</p>
        }
    </EditForm>
}

@code {
    private const string RaceId = "2026-australia";

    private Driver[]? drivers;
    private RaceConfig? raceConfig;
    private RaceQuestionMetadata? raceMetadata;
    private readonly List<string> selectedDriverIds = ["", "", "", "", ""];
    private BetType selectedBetType = BetType.Regular;
    private string? errorMessage;
    private string? successMessage;
    private bool isReadOnly;
    private PeriodicTimer? countdownTimer;
    private CancellationTokenSource? timerCts;
    private Task? tickTask;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
        StartCountdownTimer();
    }

    public async ValueTask DisposeAsync()
    {
        var cts = timerCts;
        var timer = countdownTimer;
        var task = tickTask;
        timerCts = null;
        countdownTimer = null;
        tickTask = null;

        if (cts is not null)
        {
            await cts.CancelAsync();
        }

        if (task is not null)
        {
            await task;
        }

        cts?.Dispose();
        timer?.Dispose();
    }

    private async Task LoadDataAsync()
    {
        errorMessage = null;
        successMessage = null;

        try
        {
            drivers = await Http.GetFromJsonAsync<Driver[]>("drivers") ?? System.Array.Empty<Driver>();
            raceConfig = await Http.GetFromJsonAsync<RaceConfig>($"selections/{RaceId}/config");
            raceMetadata = await LoadPublishedRaceMetadataAsync();
            await LoadExistingSelectionAsync();
            await LoadCurrentSelectionsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading data: {ex.Message}";
        }
    }

    private async Task<RaceQuestionMetadata?> LoadPublishedRaceMetadataAsync()
    {
        var response = await Http.GetAsync($"races/{RaceId}/metadata");
        if (response.StatusCode == HttpStatusCode.NotFound)
        {
            return null;
        }

        response.EnsureSuccessStatusCode();
        return await response.Content.ReadFromJsonAsync<RaceQuestionMetadata>();
    }

    private async Task LoadExistingSelectionAsync()
    {
        var response = await Http.GetAsync($"selections/{RaceId}/mine");
        if (response.StatusCode == HttpStatusCode.NotFound)
        {
            return;
        }

        response.EnsureSuccessStatusCode();

        var existing = await response.Content.ReadFromJsonAsync<Selection>();
        if (existing is null)
        {
            return;
        }

        selectedBetType = existing.BetType;
        var selections = (existing.OrderedSelections ?? [])
            .Where(item => !string.IsNullOrWhiteSpace(item.DriverId))
            .OrderBy(item => item.Position)
            .Select(item => item.DriverId)
            .ToList();

        if (selections.Count == 0)
        {
            selections = existing.Selections ?? [];
        }

        for (var i = 0; i < selectedDriverIds.Count; i++)
        {
            selectedDriverIds[i] = i < selections.Count ? selections[i] : "";
        }

        isReadOnly = existing.IsLocked;
    }

    private async Task LoadCurrentSelectionsAsync()
    {
        var snapshot = await Http.GetFromJsonAsync<CurrentSelectionItem[]>("selections/current") ?? [];

        if (snapshot.Length == 0)
        {
            return;
        }

        var rankedDrivers = snapshot
            .Where(row => !string.IsNullOrWhiteSpace(row.DriverId))
            .OrderBy(row => row.Position <= 0 ? int.MaxValue : row.Position)
            .ThenBy(row => row.Timestamp)
            .Select(row => row.DriverId)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Take(selectedDriverIds.Count)
            .ToList();

        for (var i = 0; i < selectedDriverIds.Count; i++)
        {
            selectedDriverIds[i] = i < rankedDrivers.Count ? rankedDrivers[i] : string.Empty;
        }

        var selectionType = snapshot
            .Select(row => row.SelectionType)
            .FirstOrDefault(type => !string.IsNullOrWhiteSpace(type));

        if (Enum.TryParse<BetType>(selectionType, ignoreCase: true, out var mappedBetType))
        {
            selectedBetType = mappedBetType;
        }
    }

    private async Task SaveSelectionAsync()
    {
        errorMessage = null;
        successMessage = null;

        var submission = new SelectionSubmission
        {
            BetType = selectedBetType,
            OrderedSelections = selectedDriverIds
                .Select((driverId, index) => new SelectionPosition { Position = index + 1, DriverId = driverId })
                .ToList(),
            Selections = selectedDriverIds.ToList()
        };

        try
        {
            var response = await Http.PutAsJsonAsync($"selections/{RaceId}/mine", submission);
            if (response.IsSuccessStatusCode)
            {
                successMessage = "Selection saved successfully.";
                await LoadExistingSelectionAsync();
                await LoadCurrentSelectionsAsync();
                return;
            }

            // Handle common status codes explicitly first.
            if (response.StatusCode == HttpStatusCode.Unauthorized || response.StatusCode == HttpStatusCode.Forbidden)
            {
                errorMessage = "You are not authorized to save this selection.";
                return;
            }

            var fallbackMessage = "Unable to save selection.";
            errorMessage = fallbackMessage;

            try
            {
                var content = response.Content;
                if (content is null)
                {
                    return;
                }

                var mediaType = content.Headers?.ContentType?.MediaType;
                if (string.Equals(mediaType, "application/json", StringComparison.OrdinalIgnoreCase))
                {
                    var apiError = await content.ReadFromJsonAsync<ApiErrorResponse>();
                    if (!string.IsNullOrWhiteSpace(apiError?.Message))
                    {
                        errorMessage = apiError.Message;
                    }
                    return;
                }

                // Fallback: try to read a plain-text body and use it if available.
                var text = await content.ReadAsStringAsync();
                if (!string.IsNullOrWhiteSpace(text))
                {
                    errorMessage = text;
                }
            }
            catch (Exception)
            {
                // Swallow any parsing errors and fall back to the default message.
                errorMessage = fallbackMessage;
            }
        }
        catch (HttpRequestException)
        {
            errorMessage = "Unable to save selection.";
        }
        catch (TaskCanceledException)
        {
            errorMessage = "Unable to save selection.";
        }
        catch (Exception)
        {
            errorMessage = "Unable to save selection.";
        }
    }

    private void OnDriverChanged(int index, string? driverId)
    {
        selectedDriverIds[index] = driverId ?? string.Empty;
    }

    private string GetCountdownText()
    {
        if (raceConfig is null)
        {
            return string.Empty;
        }

        var nowUtc = DateTime.UtcNow;
        var nextDeadline = nowUtc < raceConfig.PreQualyDeadlineUtc ? raceConfig.PreQualyDeadlineUtc : raceConfig.FinalDeadlineUtc;
        var label = nowUtc < raceConfig.PreQualyDeadlineUtc ? "Pre-Qualy lock" : "Final submission";

        if (nowUtc > raceConfig.FinalDeadlineUtc)
        {
            return "All deadlines have passed.";
        }

        var remaining = nextDeadline - nowUtc;
        return $"{label} in {remaining.Days}d {remaining.Hours}h {remaining.Minutes}m {remaining.Seconds}s (UTC).";
    }

    private void StartCountdownTimer()
    {
        timerCts = new CancellationTokenSource();
        countdownTimer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        tickTask = TickCountdownAsync(timerCts.Token);
    }

    private async Task TickCountdownAsync(CancellationToken cancellationToken)
    {
        if (countdownTimer is null)
        {
            return;
        }

        try
        {
            while (await countdownTimer.WaitForNextTickAsync(cancellationToken))
            {
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Unexpected error in countdown timer: {ex}");
        }
    }

    private class ApiErrorResponse
    {
        public string? Message { get; set; }
    }
}
